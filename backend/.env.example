# ── AyurWell Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it's in .gitignore.
#
# Generate a new SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-replace-with-50-char-random-string

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (use your domain in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── AI / Claude ───────────────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com/
# Required for: AI Coach, Symptom Analysis, Pulse Check, Weekly Reports
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173

# ── Audit Logging ─────────────────────────────────────────────────────────────
# Set to False to disable audit logging (not recommended in production)
AUDIT_LOG_ENABLED=True

# ── Database (optional — defaults to SQLite for development) ──────────────────
# Uncomment and configure for PostgreSQL in production:
# DATABASE_URL=postgres://user:password@localhost:5432/ayurwell

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Uses Django's LocMemCache by default. For production, use Redis:
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1

# ── Security (production only) ────────────────────────────────────────────────
# Uncomment these for HTTPS production deployment:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
